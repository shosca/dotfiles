#!/usr/bin/env python3
"""Create, switch to, or clean up git worktrees."""

import abc
import argparse
import functools
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from datetime import datetime, timezone


class GitError(Exception):
    pass


class NotAGitRepo(GitError):
    pass


class NoWorktreesFound(GitError):
    pass


@dataclass
class WorktreeInfo:
    path: str
    branch: str
    diff_added: int = 0
    diff_removed: int = 0
    age_days: int = 0


class Command(abc.ABC):
    aliases: tuple[str] = ()

    def add_args(self, subparser) -> None: ...

    def run(self, args) -> None: ...

    @functools.cached_property
    def worktrees(self) -> list[WorktreeInfo]:
        """Parse git worktree list --porcelain into WorktreeInfo objects."""
        try:
            result = subprocess.run(
                ["git", "worktree", "list", "--porcelain"],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            raise GitError(f"Failed to list worktrees: {e}")

        worktrees = []
        current_path: str | None = None
        current_branch: str | None = None

        for line in result.stdout.strip().split("\n"):
            line = line.rstrip()
            if not line:
                continue

            if line.startswith("worktree "):
                # Save previous worktree if exists
                if current_path is not None:
                    worktrees.append(
                        WorktreeInfo(path=current_path, branch=current_branch or "")
                    )
                    current_path = None
                    current_branch = None

                wt_path = line[9:].strip()

                # Skip the project root itself
                if Path(wt_path).resolve() == Path(self.project_root).resolve():
                    continue

                # Skip .git directory
                if Path(wt_path).name == ".git":
                    continue

                current_path = wt_path
            elif line.startswith("branch "):
                ref = line[7:].strip()
                if ref.startswith("refs/heads/"):
                    current_branch = ref[len("refs/heads/") :]
                else:
                    current_branch = ref
            elif line.lower().startswith("head detached"):
                current_branch = None

        if current_path is not None:
            worktrees.append(
                WorktreeInfo(path=current_path, branch=current_branch or "")
            )

        # Enrich with diff stats and age
        for wt in worktrees:
            wt.diff_added, wt.diff_removed = self._shortstat(wt.path)
            wt.age_days = self._age_days(wt.path)

        return worktrees

    @functools.cached_property
    def project_root(self) -> str:
        """Find the project root from git worktree list --porcelain."""
        try:
            result = subprocess.run(
                ["git", "worktree", "list", "--porcelain"],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            raise NotAGitRepo(f"Not a git repo: {e}")

        lines = result.stdout.strip().split("\n")
        if not lines:
            raise NoWorktreesFound("No worktrees found.")

        first_line = lines[0]
        parts = first_line.split(None, 1)
        if len(parts) < 2:
            raise GitError("Unexpected output format.")
        return parts[1].strip()

    def _colored(self, value: str, color_code: int) -> str:
        """Wrap value in ANSI color code if stdout is a TTY."""
        if sys.stdout.isatty():
            return f"\x1b[{color_code}m{value}\x1b[0m"
        return value

    def _shortstat(self, path: str) -> tuple[int, int]:
        """Return (added, removed) lines from git diff --shortstat."""
        try:
            result = subprocess.run(
                ["git", "diff", "--shortstat"],
                capture_output=True,
                text=True,
                check=True,
                cwd=path,
            )
            output = result.stdout.strip()
            if not output:
                return 0, 0
            added = removed = 0
            for part in output.split(","):
                part = part.strip()
                if "insertion" in part:
                    added = int("".join(c for c in part if c.isdigit()))
                elif "deletion" in part:
                    removed = int("".join(c for c in part if c.isdigit()))
            return added, removed
        except subprocess.CalledProcessError:
            return 0, 0

    def _default_branch(self) -> str:
        """Detect the default remote branch (main or master)."""
        try:
            result = subprocess.run(
                ["git", "symbolic-ref", "--short", "refs/remotes/origin/HEAD"],
                capture_output=True,
                text=True,
                check=True,
            )
            return result.stdout.strip()
        except subprocess.CalledProcessError:
            return "origin/master"

    def _age_days(self, path: str) -> int:
        """Return age in days of the latest commit on the current branch."""
        try:
            result = subprocess.run(
                ["git", "log", "-1", "--format=%ct"],
                capture_output=True,
                text=True,
                check=True,
                cwd=path,
            )
            commit_ts = int(result.stdout.strip())
            age = datetime.now(timezone.utc) - datetime.fromtimestamp(
                commit_ts, tz=timezone.utc
            )
            return age.days
        except (subprocess.CalledProcessError, ValueError):
            return 0

    def get_worktree_path_for_branch(self, branch_name: str) -> str | None:
        """Return the worktree path for a branch, or None."""
        for wt in self.worktrees:
            if wt.branch == branch_name:
                return wt.path
        return None

    def branch_exists(self, branch_name: str) -> bool:
        """Check if a local branch exists."""
        try:
            subprocess.run(
                ["git", "rev-parse", "--verify", branch_name],
                capture_output=True,
                text=True,
                check=True,
            )
            return True
        except subprocess.CalledProcessError:
            return False

    def find_gone_upstreams(self) -> dict[str, str]:
        """Find local branches whose upstream tracking branch is gone.

        Returns {branch_name: remote_ref} for each branch with gone upstream.
        """
        git_dir = Path(self.project_root) / ".git"
        try:
            result = subprocess.run(
                ["git", "--git-dir", git_dir, "branch", "-vv"],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            raise GitError(f"Failed to list branches: {e}")

        gone: dict[str, str] = {}
        for vv_line in result.stdout.strip().split("\n"):
            if not re.search(r"\[.*?: gone\]", vv_line):
                continue
            match = re.match(r"\s*(\S+)\s+\[(\S+?): gone\]", vv_line)
            if match:
                gone[match.group(1)] = match.group(2)

        return gone


class List(Command):
    aliases = ("ls",)

    def add_args(self, subparser):
        # gwt list — list all worktrees
        subparser.add_parser(
            "list",
            aliases=self.aliases,
            help="List all worktrees with branch, age, and diff status.",
            formatter_class=argparse.RawTextHelpFormatter,
            description=(
                "Display a table of all git worktrees showing path, branch name,\n"
                "age in days, and uncommitted changes (added/removed lines).\n"
                "Worktrees are sorted by age (oldest first).\n"
            ),
        )

    def run(self, args):
        """Handle the 'gwt list' subcommand."""

        if not self.worktrees:
            print("📭 No worktrees found.")
            return

        rows: list[tuple[str, str, str, int, int]] = []
        for wt in sorted(self.worktrees, key=lambda w: w.age_days, reverse=True):
            path_short = Path(wt.path).name
            branch_display = wt.branch if wt.branch else "(detached)"
            age = f"{wt.age_days}d" if wt.age_days > 0 else "current"
            rows.append(
                (path_short, branch_display, age, wt.diff_added, wt.diff_removed)
            )

        # Calculate dynamic column widths (with padding)
        col0 = max(4, max(len(r[0]) for r in rows) + 2)
        col1 = max(6, max(len(r[1]) for r in rows) + 2)
        col2 = max(3, max(len(r[2]) for r in rows) + 2)
        col3 = max(3, max(len(f"+{r[3]:,}" if r[3] else "-") for r in rows) + 2)
        col4 = max(3, max(len(f"-{r[4]:,}" if r[4] else "-") for r in rows) + 2)

        fmt = (
            "{:"
            + str(col0)
            + "s}  {:<"
            + str(col1)
            + "s}  {:>"
            + str(col2)
            + "s}  {:>"
            + str(col3)
            + "s}  {:>"
            + str(col4)
            + "s}"
        )
        print(fmt.format("Path", "Branch", "Age", "+", "-"))
        print("-" * (col0 + col1 + col2 + col3 + col4 + 8))

        for path_short, branch_display, age, diff_added, diff_removed in rows:
            added = f"+{diff_added:,}" if diff_added else "-"
            removed = f"-{diff_removed:,}" if diff_removed else "-"
            # Pad plain values first, then colorize only the value (preserving total width)
            pad3 = " " * (col3 - len(added))
            pad4 = " " * (col4 - len(removed))
            if diff_added > 0:
                added_str = pad3 + self._colored(added, 32)
            else:
                added_str = pad3 + self._colored(added, 90)
            if diff_removed > 0:
                removed_str = pad4 + self._colored(removed, 31)
            else:
                removed_str = pad4 + self._colored(removed, 90)
            print(
                f"{path_short:>{col0}}  {branch_display:<{col1}}  {age:>{col2}}  {added_str}  {removed_str}"
            )


class Cleanup(Command):
    def add_args(self, subparser):
        # gwt cleanup — cleanup subcommand
        cleanup_parser = subparser.add_parser(
            "cleanup", help="Delete worktrees with gone upstreams."
        )
        cleanup_parser.add_argument(
            "-y",
            "--yes",
            action="store_true",
            help="Skip confirmation prompt.",
        )
        cleanup_parser.add_argument(
            "--dry-run",
            action="store_true",
            help="Show what would be deleted without making changes.",
        )

    def run(self, args):
        """Handle the 'gwt cleanup' subcommand."""
        gone_upstreams = self.find_gone_upstreams()

        # Cross-reference: only show worktrees that have gone upstreams
        candidates = [wt for wt in self.worktrees if wt.branch in gone_upstreams]
        others = [
            wt for wt in self.worktrees if wt.branch and wt.branch not in gone_upstreams
        ]

        gone_count = len(candidates)
        active_count = len(others)

        # Print skipped worktrees (detached / no branch)
        detached = [wt for wt in self.worktrees if not wt.branch]
        detached_count = len(detached)
        total_worktrees = gone_count + active_count + detached_count
        for wt in detached:
            print(f"⏺️  {Path(wt.path).name} (no branch — skip)")

        # Print summary
        print()
        print(
            f"  📊 Total: {total_worktrees} worktrees "
            f"| Gone upstream: {gone_count} "
            f"| Active: {active_count} "
            f"| Detached: {detached_count}"
        )
        print()

        if gone_count == 0:
            print("🛡️  No worktrees have gone upstreams. Nothing to clean.")
            return

        print(f"  ✅ Can clean ({gone_count}):")
        for wt in candidates:
            remote_ref = gone_upstreams[wt.branch]
            print(f"     • {wt.branch} (upstream {remote_ref})")
        print()

        if others:
            print("  🟢 Active (keeping):")
            for wt in others:
                print(f"     • {wt.branch}")
            print()

        print("=" * 50)

        if args.dry_run:
            print("\n🔍 Dry run — no changes were made.")
            return

        # Skip prompt with -y flag
        if args.yes:
            answer = "y"
        else:
            answer = (
                input(f"\nDelete {gone_count} worktree(s)? (y/n) [n]: ").strip().lower()
            )

        if answer not in ("y", "yes"):
            print("❌ Cancelled.")
            return

        deleted = 0
        failed = 0

        for wt in candidates:
            remote_ref = gone_upstreams[wt.branch]
            print(f"  🗑️  {wt.branch} (upstream {remote_ref} is gone)")

            try:
                subprocess.run(
                    ["git", "worktree", "remove", wt.path],
                    capture_output=True,
                    text=True,
                    check=True,
                )
            except subprocess.CalledProcessError as e:
                print(f"     ⚠️  Failed to remove worktree: {e.stderr.strip()}")
                failed += 1
                continue

            try:
                subprocess.run(
                    ["git", "branch", "-D", wt.branch],
                    capture_output=True,
                    text=True,
                    check=True,
                )
                deleted += 1
            except subprocess.CalledProcessError as e:
                print(f"     ⚠️  Failed to delete branch: {e.stderr.strip()}")
                failed += 1

        print()
        print(f"  🗑️  Deleted: {deleted} | Failed: {failed}")


class Delete(Command):
    aliases = ("rm",)

    def add_args(self, subparser):
        # gwt delete <branch|path> — delete a worktree
        delete_sub = subparser.add_parser(
            "delete",
            aliases=self.aliases,
            help="Delete a worktree by branch name or path.",
            formatter_class=argparse.RawTextHelpFormatter,
            description=(
                "Remove an existing worktree and its branch.\n"
                "\n"
                "Accepts either the branch name or the worktree directory basename.\n"
                "Cannot delete the main worktree (project root).\n"
            ),
        )
        delete_sub.add_argument(
            "target",
            help="Branch name or worktree path to delete.",
        )
        delete_sub.add_argument(
            "-y",
            "--yes",
            action="store_true",
            help="Skip confirmation prompt.",
        )

    def run(self, args):
        """Handle the 'gwt delete' subcommand."""
        target = args.target

        # Resolve target to a worktree entry — match by branch or path basename
        matched: WorktreeInfo | None = None
        for wt in self.worktrees:
            if wt.branch == target or Path(wt.path).name == target:
                matched = wt
                break

        if not matched:
            print(f"❌ No worktree found matching: {target}")
            print("   Use 'gwt list' to see available worktrees.")
            return

        # Refuse to delete the main worktree (project root)
        if Path(matched.path).resolve() == Path(self.project_root).resolve():
            print(f"❌ Cannot delete the main worktree: {matched.path}")
            return

        print(f"Deleting: {matched.branch} ({matched.path})")

        if not args.yes:
            answer = input("Continue? (y/n) [n]: ").strip().lower()
            if answer not in ("y", "yes"):
                print("❌ Cancelled.")
                return

        # Remove worktree
        try:
            subprocess.run(
                ["git", "worktree", "remove", matched.path],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            print(f"❌ Failed to remove worktree: {e.stderr.strip()}")
            sys.exit(1)

        print(f"✅ Worktree removed: {matched.path}")


class Completions(Command):
    COMPLETIONS = {
        "zsh": (
            """#compdef gwt

_gwt() {
    local cur="$words[CURRENT]"
    
    if (( CURRENT == 2 )); then
        _values 'subcommands' checkout cleanup delete list pr completions
    elif (( CURRENT == 3 )); then
        case $words[2] in
            checkout)
                local -a branches
                branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
                _describe 'branch' branches
                ;;
            cleanup)
                _values 'flags' '-y[Skip confirmation prompt.]' '--yes[Skip confirmation prompt.]' '--dry-run[Show what would be deleted without making changes.]'
                ;;
            delete)
                local -a branches
                branches=(${(f)"$(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{p=1;next} /^branch /{if(p)print $2; p=0}' | sed 's|refs/heads/||')}"})
                _describe 'branch_or_path' branches
                ;;
            pr)
                _values 'flags' '--remote[Remote name (default: origin).]'
                ;;
            completions)
                _values 'shell' bash fish zsh
                ;;
        esac
    fi
}

_gwt
compdef _gwt gwt
"""
        ),
        "bash": (
            """__gwt() {
    local cur prev words cword
    _init_completion || return

    local subcommands="checkout cleanup delete list pr completions"

    if [[ $cword -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$subcommands" -- "$cur") )
        return
    fi

    prev="${words[cword-2]}"
    if [[ "$prev" == "checkout" ]]; then
        local branches
        branches=$(git branch --format='%(refname:short)' 2>/dev/null)
        COMPREPLY=( $(compgen -W "$branches" -- "$cur") )
    elif [[ "$prev" == "delete" ]]; then
        local wt_branches
        wt_branches=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{p=1;next} /^branch /{if(p)print $2; p=0}' | sed 's|refs/heads/||')
        COMPREPLY=( $(compgen -W "$wt_branches" -- "$cur") )
    elif [[ "$prev" == "pr" ]]; then
        local flags="--remote"
        COMPREPLY=( $(compgen -W "$flags" -- "$cur") )
    elif [[ "$prev" == "cleanup" ]]; then
        COMPREPLY=( $(compgen -W "--dry-run --yes" -- "$cur") )
    elif [[ "$prev" == "completions" ]]; then
        COMPREPLY=( $(compgen -W "bash fish zsh" -- "$cur") )
    fi
}

complete -F __gwt gwt
"""
        ),
        "fish": (
            r"""
complete -c gwt -s h -l help -d 'Show help'
complete -c gwt -f -n '__fish_use_subcommand' -a checkout -d 'Create or switch to a git worktree.'
complete -c gwt -f -n '__fish_use_subcommand' -a cleanup -d 'Delete worktrees with gone upstreams.'
complete -c gwt -f -n '__fish_use_subcommand' -a completions -d 'Print shell completion scripts to stdout.'
complete -c gwt -f -n '__fish_use_subcommand' -a delete -d 'Delete a worktree by branch name or path.'
complete -c gwt -f -n '__fish_use_subcommand' -a list -d 'List all worktrees with branch, age, and diff status.'
complete -c gwt -f -n '__fish_use_subcommand' -a pr -d 'Checkout a GitHub PR in a new worktree.'
complete -c gwt -n '__fish_seen_subcommand checkout' -a "(git branch --format='%(refname:short)' 2>/dev/null)"
complete -c gwt -n '__fish_seen_subcommand delete' -a "(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{p=1;next} /^branch /{if(p)print $2; p=0}' | sed 's|refs/heads/||')"
complete -c gwt -n '__fish_seen_subcommand delete' -s y -l yes -d 'Skip confirmation prompt.'
complete -c gwt -n '__fish_seen_subcommand cleanup' -s y -l yes -d 'Skip confirmation prompt.'
complete -c gwt -n '__fish_seen_subcommand cleanup' -l dry-run -d 'Show what would be deleted without making changes.'
complete -c gwt -n '__fish_seen_subcommand pr' -l remote -d 'Remote name (default: origin).'
complete -c gwt -n '__fish_seen_subcommand completions' -a "bash fish zsh" -d 'Shell type for completion script.'

"""
        ),
    }

    def add_args(self, subparser):
        # gwt completions <shell> — print shell completion scripts
        completions_sub = subparser.add_parser(
            "completions",
            help="Print shell completion scripts to stdout.",
            formatter_class=argparse.RawTextHelpFormatter,
            description=(
                "Prints the auto-completion script for bash, fish, or zsh to stdout.\n"
                "Source it in your shell config to enable tab-completion for gwt.\n"
            ),
        )
        completions_sub.add_argument(
            "shell",
            choices=["bash", "fish", "zsh"],
            help="Shell type for completion script.",
        )

    def run(self, args):
        print(self.COMPLETIONS[args.shell])
        return


class Checkout(Command):
    aliases = ("co",)

    def add_args(self, subparser):
        # gwt checkout <branch> — explicit subcommand for worktree creation
        checkout_parser = subparser.add_parser(
            "checkout",
            aliases=self.aliases,
            help="Create or switch to a git worktree.",
            formatter_class=argparse.RawTextHelpFormatter,
            description=(
                "Create a new worktree or switch to an existing one.\n"
                "\n"
                "Behavior:\n"
                "  • If the worktree dir exists → switches into it\n"
                "  • If branch has a worktree elsewhere → switches there\n"
                "  • If branch exists locally → creates new worktree from it\n"
                "  • If branch doesn't exist → creates new branch from base\n"
            ),
        )
        checkout_parser.add_argument("branch", help="Branch name")
        checkout_parser.add_argument(
            "base",
            nargs="?",
            default="__detect__",
            help="Base branch (auto-detected from origin/HEAD)",
        )

    def run(self, args):
        """Handle the 'gwt checkout' subcommand."""
        worktree_path = Path(self.project_root) / args.branch

        # Case 1: Worktree dir already exists → cd into it
        if Path(worktree_path).is_dir():
            return

        # Case 2: Branch has a worktree somewhere → cd into it
        existing_wt = self.get_worktree_path_for_branch(args.branch)
        if existing_wt:
            return

        # Case 3: Branch exists locally → create worktree from it (no branch changes)
        if self.branch_exists(args.branch):
            try:
                subprocess.run(
                    ["git", "worktree", "add", worktree_path, args.branch],
                    cwd=self.project_root,
                    capture_output=True,
                    text=True,
                    check=True,
                )
            except subprocess.CalledProcessError as e:
                stderr = e.stderr.strip() if e.stderr else "unknown error"
                print(f"❌ Failed to create worktree: {stderr}", file=sys.stderr)
                sys.exit(1)
            print(f"📂 Worktree created from existing branch: {args.branch}")
            return

        # Case 4: Branch doesn't exist → create new branch
        base = self._default_branch() if args.base == "__detect__" else args.base
        if self.branch_exists(f"origin/{args.branch}"):
            base = f"origin/{args.branch}"

        try:
            subprocess.run(
                ["git", "worktree", "add", worktree_path, "-b", args.branch, base],
                cwd=self.project_root,
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            stderr = e.stderr.strip() if e.stderr else "unknown error"
            print(f"❌ Failed to create worktree: {stderr}", file=sys.stderr)
            sys.exit(1)

        if base == f"origin/{args.branch}":
            print(f"🚀 Ready to work on: {args.branch} (tracking {base})")
        else:
            print(f"🚀 Ready to work on: {args.branch}")


class Pr(Command):
    def add_args(self, subparser):
        pr_parser = subparser.add_parser(
            "pr",
            help="Checkout a GitHub PR in a new worktree.",
            formatter_class=argparse.RawTextHelpFormatter,
            description=(
                "Fetch a pull request and create a worktree for it.\n"
                "\n"
                "Behavior:\n"
                "  • Fetches `pull/<N>/head` from the remote\n"
                "  • Creates local branch `pr/N` at that commit\n"
                "  • Creates a worktree at path `pr-N`\n"
                "  • If the worktree already exists → switches into it\n"
            ),
        )
        pr_parser.add_argument("number", help="Pull request number")
        pr_parser.add_argument(
            "--remote",
            default="origin",
            help="Remote name (default: origin)",
        )

    def run(self, args):
        pr_number = args.number
        remote = args.remote
        branch_name = f"pr/{pr_number}"
        worktree_path = Path(self.project_root) / f"pr-{pr_number}"

        # Case 1: Worktree dir already exists → cd into it
        if Path(worktree_path).is_dir():
            return

        # Case 2: Branch has a worktree somewhere → cd into it
        existing_wt = self.get_worktree_path_for_branch(branch_name)
        if existing_wt:
            return

        # Fetch the PR
        try:
            subprocess.run(
                ["git", "fetch", remote, f"pull/{pr_number}/head"],
                cwd=self.project_root,
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            stderr = e.stderr.strip() if e.stderr else "unknown error"
            print(f"❌ Failed to fetch PR #{pr_number}: {stderr}", file=sys.stderr)
            sys.exit(1)

        # Create the local branch at the fetched commit
        try:
            subprocess.run(
                ["git", "branch", branch_name, "FETCH_HEAD"],
                cwd=self.project_root,
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            stderr = e.stderr.strip() if e.stderr else "unknown error"
            print(
                f"❌ Failed to create branch pr/{pr_number}: {stderr}", file=sys.stderr
            )
            sys.exit(1)

        # Create worktree from the local branch
        try:
            subprocess.run(
                ["git", "worktree", "add", worktree_path, branch_name],
                cwd=self.project_root,
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as e:
            stderr = e.stderr.strip() if e.stderr else "unknown error"
            print(f"❌ Failed to create worktree: {stderr}", file=sys.stderr)
            sys.exit(1)

        print(f"🔍 Ready to review PR #{pr_number}")


COMMANDS = {
    Completions,
    Checkout,
    Cleanup,
    List,
    Delete,
    Pr,
}


def main():
    parser = argparse.ArgumentParser(
        description="Create, switch to, or clean up git worktrees."
    )
    subparser = parser.add_subparsers(dest="command")

    commands = {}
    for cmd in COMMANDS:
        command = cmd()
        command.add_args(subparser)
        commands[cmd.__name__.lower()] = command
        for alias in command.aliases:
            commands[alias] = command

    args = parser.parse_args()
    try:
        if command := commands.get(args.command):
            command.run(args)
        else:
            parser.print_help()
    except NotAGitRepo as e:
        print(f"❌ {e}", file=sys.stderr)
        sys.exit(1)
    except NoWorktreesFound as e:
        print(f"📭 {e}", file=sys.stderr)
        sys.exit(0)
    except GitError as e:
        print(f"❌ {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
