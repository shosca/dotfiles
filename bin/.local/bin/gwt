#!/usr/bin/env python3
"""Create or switch to a git worktree."""

import argparse
import os
import subprocess
import sys


def find_project_root() -> str:
    """Find the project root from git worktree list --porcelain."""
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"❌ Not a git repo: {e}", file=sys.stderr)
        sys.exit(1)

    lines = result.stdout.strip().split("\n")
    if not lines:
        print("📭 No worktrees found.", file=sys.stderr)
        sys.exit(0)

    first_line = lines[0]
    parts = first_line.split(None, 1)
    if len(parts) < 2:
        print("❌ Unexpected output format.", file=sys.stderr)
        sys.exit(1)
    return parts[1].strip()


def get_worktree_for_branch(branch_name: str, project_root: str) -> str | None:
    """Check if branch already has a worktree. Returns path or None."""
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError:
        return None

    current_path: str | None = None
    for line in result.stdout.strip().split("\n"):
        line = line.rstrip()
        if not line:
            continue
        if line.startswith("worktree "):
            current_path = line[9:].strip()
        elif line.startswith("branch ") and current_path is not None:
            ref = line[7:].strip()
            if ref == f"refs/heads/{branch_name}" or ref == branch_name:
                if os.path.abspath(current_path).startswith(os.path.abspath(project_root)):
                    return current_path
        elif line.lower().startswith("head detached"):
            current_path = None

    return None


def branch_exists(branch_name: str) -> bool:
    """Check if a local branch exists."""
    try:
        subprocess.run(
            ["git", "rev-parse", "--verify", branch_name],
            capture_output=True, text=True, check=True,
        )
        return True
    except subprocess.CalledProcessError:
        return False


def main():
    parser = argparse.ArgumentParser(description="Create or switch to a git worktree.")
    parser.add_argument("branch_name", help="Branch name")
    parser.add_argument(
        "base_branch", nargs="?", default="origin/master",
        help="Base branch (default: origin/master)",
    )
    args = parser.parse_args()

    project_root = find_project_root()
    worktree_path = os.path.join(project_root, args.branch_name)

    # Case 1: Worktree dir already exists → cd into it
    if os.path.isdir(worktree_path):
        print(f"📂 Worktree already exists, switching to: {args.branch_name}")
        os.chdir(worktree_path)
        return

    # Case 2: Branch has a worktree somewhere → cd into it
    existing_wt = get_worktree_for_branch(args.branch_name, project_root)
    if existing_wt:
        print(f"📂 Worktree already exists at {existing_wt}, switching to: {args.branch_name}")
        os.chdir(existing_wt)
        return

    # Case 3: Branch exists locally → create worktree from it (no branch changes)
    if branch_exists(args.branch_name):
        try:
            subprocess.run(
                ["git", "worktree", "add", worktree_path, args.branch_name],
                cwd=project_root,
                capture_output=True, text=True, check=True,
            )
        except subprocess.CalledProcessError as e:
            stderr = e.stderr.strip() if e.stderr else "unknown error"
            print(f"❌ Failed to create worktree: {stderr}", file=sys.stderr)
            sys.exit(1)
        os.chdir(worktree_path)
        print(f"📂 Worktree created from existing branch: {args.branch_name}")
        return

    # Case 4: Branch doesn't exist → create new branch
    # Prefer origin/<branch_name>, fall back to base_branch (default: origin/master)
    base = args.base_branch
    if branch_exists(f"origin/{args.branch_name}"):
        base = f"origin/{args.branch_name}"

    try:
        subprocess.run(
            ["git", "worktree", "add", worktree_path, "-b", args.branch_name, base],
            cwd=project_root,
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        stderr = e.stderr.strip() if e.stderr else "unknown error"
        print(f"❌ Failed to create worktree: {stderr}", file=sys.stderr)
        sys.exit(1)

    os.chdir(worktree_path)
    if base == f"origin/{args.branch_name}":
        print(f"🚀 Ready to work on: {args.branch_name} (tracking {base})")
    else:
        print(f"🚀 Ready to work on: {args.branch_name}")


if __name__ == "__main__":
    main()
