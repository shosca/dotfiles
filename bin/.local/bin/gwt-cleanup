#!/usr/bin/env python3
"""Scan git worktrees, find branches whose remote tracking branch is gone, batch delete."""

import argparse
import os
import subprocess
import sys
from dataclasses import dataclass


@dataclass
class Worktree:
    path: str
    branch: str  # local branch name


def find_project_root() -> str:
    """Find the project root from git worktree list --porcelain."""
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"❌ Not a git repo: {e}", file=sys.stderr)
        sys.exit(1)

    lines = result.stdout.strip().split("\n")
    if not lines:
        print("📭 No worktrees found.", file=sys.stderr)
        sys.exit(0)

    first_line = lines[0]
    parts = first_line.split(None, 1)
    if len(parts) < 2:
        print("❌ Unexpected output format.", file=sys.stderr)
        sys.exit(1)
    return parts[1].strip()


def parse_worktrees(project_root: str) -> list[Worktree]:
    """Parse git worktree list --porcelain into Worktree objects."""
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"❌ Failed to list worktrees: {e}", file=sys.stderr)
        sys.exit(1)

    worktrees = []
    current_path: str | None = None
    current_branch: str | None = None

    for line in result.stdout.strip().split("\n"):
        line = line.rstrip()
        if not line:
            continue

        if line.startswith("worktree "):
            # Save previous worktree if exists
            if current_path is not None:
                worktrees.append(Worktree(path=current_path, branch=current_branch or ""))
                current_path = None
                current_branch = None

            wt_path = line[9:].strip()

            # Skip the project root itself
            if os.path.abspath(wt_path) == os.path.abspath(project_root):
                continue

            # Skip .git directory
            if os.path.basename(wt_path) == ".git":
                continue

            current_path = wt_path
        elif line.startswith("branch "):
            ref = line[7:].strip()
            if ref.startswith("refs/heads/"):
                current_branch = ref[len("refs/heads/"):]
            else:
                current_branch = ref
        elif line.lower().startswith("head detached"):
            current_branch = None

    if current_path is not None:
        worktrees.append(Worktree(path=current_path, branch=current_branch or ""))

    return worktrees


def find_gone_upstreams() -> dict[str, str]:
    """Find local branches whose upstream tracking branch is gone.
    
    Returns {branch_name: remote_ref} for each branch with gone upstream.
    """
    try:
        result = subprocess.run(
            ["git", "branch", "-vv", "--format=%(refname:short)|%(upstream:short)"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        print(f"❌ Failed to list branches: {e}", file=sys.stderr)
        sys.exit(1)

    gone: dict[str, str] = {}

    # Also need the upstream status. Check with git for each branch.
    result2 = subprocess.run(
        ["git", "branch", "-vv"],
        capture_output=True, text=True, check=True,
    )

    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("|")
        if len(parts) != 2:
            continue
        branch_name = parts[0].strip()
        remote_ref = parts[1].strip()
        
        # Check if this branch appears as gone in the -vv output
        for vv_line in result2.stdout.strip().split("\n"):
            if branch_name in vv_line and "[gone]" in vv_line:
                gone[branch_name] = remote_ref
                break

    return gone


def clean_worktrees(
    worktrees: list[Worktree], gone_upstreams: dict[str, str]
) -> tuple[int, int]:
    """Delete worktrees whose branches have gone upstreams. Returns (deleted, failed)."""
    deleted = 0
    failed = 0

    for wt in worktrees:
        if wt.branch in gone_upstreams:
            remote_ref = gone_upstreams[wt.branch]
            print(f"  🗑️  {wt.branch} (upstream {remote_ref} is gone)")

            try:
                subprocess.run(
                    ["git", "worktree", "remove", wt.path],
                    capture_output=True, text=True, check=True,
                )
            except subprocess.CalledProcessError as e:
                print(f"     ⚠️  Failed to remove worktree: {e.stderr.strip()}")
                failed += 1
                continue

            try:
                subprocess.run(
                    ["git", "branch", "-D", wt.branch],
                    capture_output=True, text=True, check=True,
                )
                deleted += 1
            except subprocess.CalledProcessError as e:
                print(f"     ⚠️  Failed to delete branch: {e.stderr.strip()}")
                failed += 1

    return deleted, failed


def main():
    parser = argparse.ArgumentParser(
        description="Scan git worktrees and batch-delete those with gone upstreams."
    )
    parser.add_argument(
        "-y", "--yes", action="store_true",
        help="Skip confirmation prompt.",
    )
    args = parser.parse_args()

    project_root = find_project_root()
    worktrees = parse_worktrees(project_root)
    gone_upstreams = find_gone_upstreams()

    # Cross-reference: only show worktrees that have gone upstreams
    candidates = [wt for wt in worktrees if wt.branch in gone_upstreams]
    others = [wt for wt in worktrees if wt.branch not in gone_upstreams]

    total_worktrees = len(worktrees)
    gone_count = len(candidates)
    active_count = len(others)

    # Print skipped worktrees (detached / no branch)
    detached = [wt for wt in worktrees if not wt.branch]
    for wt in detached:
        print(f"⏺️  {os.path.basename(wt.path)} (no branch — skip)")

    if total_worktrees == 0:
        print("📭 No worktrees found.")
        return

    # Print summary
    print()
    print("=" * 50)
    print("  gwt-clean-all — Worktree Cleanup Scan")
    print("=" * 50)
    print()
    print(
        f"  📊 Total: {total_worktrees} worktrees "
        f"| Gone upstream: {gone_count} "
        f"| Active: {active_count}"
    )
    print()

    if gone_count == 0:
        print("🛡️  No worktrees have gone upstreams. Nothing to clean.")
        return

    print(f"  ✅ Can clean ({gone_count}):")
    for wt in candidates:
        remote_ref = gone_upstreams[wt.branch]
        print(f"     • {wt.branch} (upstream {remote_ref})")
    print()

    if others:
        print("  🟢 Active (keeping):")
        for wt in others:
            print(f"     • {wt.branch}")
        print()

    print("=" * 50)

    # Skip prompt with -y flag
    if args.yes:
        answer = "y"
    else:
        answer = input(f"\nDelete {gone_count} worktree(s)? (y/n) [n]: ").strip().lower()

    if answer not in ("y", "yes"):
        print("❌ Cancelled.")
        return

    print()
    deleted, failed = clean_worktrees(candidates, gone_upstreams)

    print()
    print(f"  🗑️  Deleted: {deleted} | Failed: {failed}")


if __name__ == "__main__":
    main()
